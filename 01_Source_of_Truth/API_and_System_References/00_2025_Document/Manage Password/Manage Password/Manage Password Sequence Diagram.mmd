sequenceDiagram
	title Manage Password Sequence

	actor U as User
	participant A as One Bangkok App
	participant S as Auth Service

	U->>A: Open Manage Password

	rect rgb(245, 250, 255)
		Note over U,A: 1) Check current password
		U->>A: Input current password
		A->>S: Verify current password
		S-->>A: Verification result

		alt Current password is valid
			A-->>U: Navigate to ManagePasswordScreen
		else Current password is invalid
			A-->>U: Show validation error
			A-->>U: Ask user to input current password again
		end
	end

	rect rgb(247, 255, 247)
		Note over U,A: 2) Create new password
		U->>A: Input new password
		A->>A: Validate password rules

		alt New password is valid
			A-->>U: Navigate to ConfirmPasswordScreen
		else New password is invalid
			A-->>U: Show validation error
			A-->>U: Ask user to input new password again
		end
	end

	rect rgb(255, 249, 245)
		Note over U,A: 3) Confirm set password
		U->>A: Input confirm password
		A->>A: Compare with new password

		alt Confirm password matches
			A->>S: Set new password
			S-->>A: Password updated
			A-->>U: Show success message
		else Confirm password does not match
			A-->>U: Show validation error
			A-->>U: Stay on ConfirmPasswordScreen
		end
	end