---




config:
  layout: elk
---
flowchart TD
    START([START]) --> CheckCurrent[Check current password]
    CheckCurrent --> EnterCurrent[User enters current password]
    EnterCurrent --> MatchCurrent{Password matches?}
    
    MatchCurrent -->|Yes| Navigate1[Navigate to ManagePasswordScreen]
    MatchCurrent -->|No| ErrorCurrent[Show validation error]
    ErrorCurrent --> EnterCurrent
    
    Navigate1 --> CreateNew[Create new password]
    CreateNew --> EnterNew[User enters new password]
    EnterNew --> ValidateNew{Password valid<br/>against rules?}
    
    ValidateNew -->|Yes| Navigate2[Navigate to ConfirmPasswordScreen]
    ValidateNew -->|No| ErrorNew[Show validation error]
    ErrorNew --> EnterNew
    
    Navigate2 --> ConfirmStep[Confirm new password]
    ConfirmStep --> EnterConfirm[User enters confirm password]
    EnterConfirm --> MatchConfirm{Confirm password<br/>matches new password?}
    
    MatchConfirm -->|Yes| SetPassword[Set new password]
    SetPassword --> SuccessMsg[Show success message]
    SuccessMsg --> END([END])
    
    MatchConfirm -->|No| ErrorConfirm[Show validation error]
    ErrorConfirm --> EnterConfirm
    
    classDef processNode stroke:#818cf8,fill:#eef2ff,color:#1e1b4b
    classDef decisionNode stroke:#a78bfa,fill:#f5f3ff,color:#1e1b4b
    classDef successNode stroke:#4ade80,fill:#f0fdf4,color:#1e1b4b
    classDef errorNode stroke:#f87171,fill:#fef2f2,color:#1e1b4b
    classDef startEndNode stroke:#fb923c,fill:#fff7ed,color:#1e1b4b
    
    class CheckCurrent,CreateNew,ConfirmStep,EnterCurrent,EnterNew,EnterConfirm,SetPassword processNode
    class MatchCurrent,ValidateNew,MatchConfirm decisionNode
    class SuccessMsg,Navigate1,Navigate2 successNode
    class ErrorCurrent,ErrorNew,ErrorConfirm errorNode
    class START,END startEndNode