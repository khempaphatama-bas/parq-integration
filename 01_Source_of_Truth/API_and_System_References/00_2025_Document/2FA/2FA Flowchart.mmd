---
config:
  layout: elk
---
flowchart TD
    START([START]) --> Enable2FA[Enable 2FA]

    Enable2FA --> CheckContacts{User has both<br/>email & phone?}

    %% Contact check
    CheckContacts -->|Yes| Enable2FAScreen[Navigate to<br/>Enable2FAScreen]
    CheckContacts -->|Missing Email| AddEmailScreen[Navigate to<br/>AddEmailScreen]
    CheckContacts -->|Missing Phone| AddPhoneScreen[Navigate to<br/>AddPhoneScreen]

    %% Email flow
    AddEmailScreen --> EnterEmail[User enters<br/>new email]
    EnterEmail --> ValidateEmail{Email format valid?}
    ValidateEmail -->|No| ShowEmailError[Show validation error]
    ShowEmailError --> EnterEmail
    ValidateEmail -->|Yes| SendOTP[Send OTP]

    %% Phone flow
    AddPhoneScreen --> EnterPhone[User enters<br/>new phone number]
    EnterPhone --> ValidatePhone{Phone number valid?}
    ValidatePhone -->|No| ShowPhoneError[Show validation error]
    ShowPhoneError --> EnterPhone
    ValidatePhone -->|Yes| SendOTP[Send OTP]

    %% Shared OTP flow
    SendOTP --> OTPVerifyScreen[Navigate to<br/>OTP Verify Screen]

    OTPVerifyScreen --> EnterOTP[Enter OTP]
    EnterOTP --> CheckOTP{OTP correct?}

    CheckOTP -->|No| ShowErrorOTP[Show OTP varify error]
    ShowErrorOTP --> EnterOTP[Enter OTP]
    CheckOTP -->|Yes| Enable2FAScreen
	Enable2FAScreen --> CreateIdentity[Create New Identity]

    %% Enable 2FA
    CreateIdentity --> ConfirmEnable{User confirms<br/>enable 2FA?}
    ConfirmEnable -->|No| END1([END])
    ConfirmEnable -->|Yes| SuccessMsg[Show success message]
    SuccessMsg --> END2([END])

    %% Styles
    classDef startEnd fill:#f0fdf4,stroke:#22c55e,color:#111827,stroke-width:2px
    classDef decision fill:#fef2f2,stroke:#ef4444,color:#111827,stroke-width:2px
    classDef screen fill:#eff6ff,stroke:#3b82f6,color:#111827,stroke-width:2px
    classDef action fill:#eef2ff,stroke:#6366f1,color:#111827,stroke-width:2px
    classDef error fill:#fff7ed,stroke:#f97316,color:#111827,stroke-width:2px

    class START,END1,END2 startEnd
    class CheckContacts,ValidateEmail,ValidatePhone,CheckOTP,ConfirmEnable decision
    class Enable2FAScreen,AddEmailScreen,AddPhoneScreen,OTPVerifyScreen screen
    class Enable2FA,SendOTP,SendOTP,EnterEmail,EnterPhone,EnterOTP,SuccessMsg action
    class ShowEmailError,ShowPhoneError,ShowErrorOTP error